---
// src/components/TeamGrid.astro
---
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold text-gray-900 mb-12">Meet Our Team</h2>
    <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      
      <!-- Koumba's Profile Card -->
      <li class="col-span-1 sm:col-start-1 md:col-start-2 md:col-span-2 flex flex-col text-center bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-2xl transition-shadow duration-300">
        <div class="flex-1 flex flex-col p-10">
          
          <!-- Premium Portrait Image -->
          <!-- Save your photo as 'koumba-portrait' in the public folder -->
          <img loading="lazy" class="w-40 h-40 flex-shrink-0 mx-auto rounded-full object-cover border-4 border-gray-50 shadow-md mb-6" src="/koumba-portrait.webp.jpg" alt="Koumba R Koundouno" />
          
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Koumba R Koundouno</h3>
          <p class="text-blue-600 font-medium text-sm mb-6 uppercase tracking-wide">Founder & Advisor</p>
          
          <dl class="flex-grow flex flex-col justify-between">
            <dt class="sr-only">Bio</dt>
            <dd class="text-gray-600 leading-relaxed text-left italic">
              "I believe every family deserves to understand their financial future. I work with individuals, professionals, and business owners to simplify financial protection strategies and create plans that adapt to life's changes. Through education and thoughtful guidance, I help families move from uncertainty to clarity and confidence."
            </dd>
          </dl>
        </div>
      </li>

    </ul>
  </div>
</section>
