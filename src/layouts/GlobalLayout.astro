---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Infinite Wealth Academy', description = 'Helping families protect, grow, and control their financial future. Financial clarity, strategic protection, and generational confidence. Project 500 Families by 2027.' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body class="font-sans antialiased text-slate-900 bg-white flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-slate-900 focus:rounded-md">Skip to main content</a>

    <!-- Sticky Header (Dark slate – Amadeus-style) -->
    <header class="sticky top-0 z-50 w-full bg-slate-900 border-b border-slate-800 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <a href="/" class="flex-shrink-0 flex items-center gap-3 cursor-pointer">
            <img src="/logo-gold.svg.png" alt="Infinite Wealth Academy" class="h-10 w-auto" onerror="this.onerror=null; this.src='/logo.svg'; this.classList.add('brightness-0','invert');" />
            <span class="font-extrabold text-xl text-white tracking-tight">Infinite Wealth Academy</span>
          </a>

          <nav class="hidden md:flex space-x-8">
            <a href="/" class="text-slate-300 hover:text-amber-400 font-medium transition-colors">Home</a>
            <a href="/about" class="text-slate-300 hover:text-amber-400 font-medium transition-colors">About Us / Mission</a>
            <a href="/who-we-help" class="text-slate-300 hover:text-amber-400 font-medium transition-colors">Who We Help</a>
          </nav>

          <div class="hidden md:flex items-center">
            <a href="https://calendly.com/500families-infinitewealthacademy/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-bold rounded-md text-white bg-gradient-to-r from-yellow-500 to-amber-600 hover:from-yellow-400 hover:to-amber-500 transition-all shadow-md">
              Get a Free Consultation
            </a>
          </div>

          <div class="flex md:hidden items-center">
            <button type="button" id="mobile-menu-button" class="p-2 rounded-md text-slate-300 hover:text-amber-400 hover:bg-slate-800" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
              <svg class="w-6 h-6 menu-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
              <svg class="w-6 h-6 menu-close hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 py-4" aria-label="Mobile navigation">
          <nav class="flex flex-col gap-2">
            <a href="/" class="px-2 py-2 text-slate-300 hover:text-amber-400 hover:bg-slate-800 rounded-md font-medium">Home</a>
            <a href="/about" class="px-2 py-2 text-slate-300 hover:text-amber-400 hover:bg-slate-800 rounded-md font-medium">About Us / Mission</a>
            <a href="/who-we-help" class="px-2 py-2 text-slate-300 hover:text-amber-400 hover:bg-slate-800 rounded-md font-medium">Who We Help</a>
            <a href="https://calendly.com/500families-infinitewealthacademy/30min" target="_blank" rel="noopener noreferrer" class="mt-2 inline-flex items-center justify-center px-5 py-3 text-sm font-bold rounded-md text-white bg-gradient-to-r from-yellow-500 to-amber-600">Get a Free Consultation</a>
          </nav>
        </div>
      </div>
    </header>
    <script>
      (function() {
        var btn = document.getElementById('mobile-menu-button');
        var menu = document.getElementById('mobile-menu');
        var openIcon = document.querySelector('.menu-open');
        var closeIcon = document.querySelector('.menu-close');
        if (!btn || !menu) return;
        function setOpen(open) {
          menu.classList.toggle('hidden', open);
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
          if (openIcon && closeIcon) { openIcon.classList.toggle('hidden', !open); closeIcon.classList.toggle('hidden', open); }
        }
        btn.addEventListener('click', function() { setOpen(!menu.classList.contains('hidden')); });
        menu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', function() { setOpen(true); }); });
      })();
    </script>

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <footer class="bg-slate-900 pt-16 pb-8 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
          <div class="col-span-1 md:col-span-2">
            <span class="font-extrabold text-xl text-white tracking-tight">Infinite Wealth Academy</span>
            <p class="mt-4 text-slate-400 text-sm leading-relaxed max-w-lg">
              Helping Families Protect, Grow, and Control Their Financial Future. Financial Clarity. Strategic Protection. Generational Confidence.
            </p>
          </div>
          <div class="col-span-1">
            <h4 class="text-amber-500 font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2 text-sm text-slate-400">
              <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
              <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
              <li><a href="/who-we-help" class="hover:text-white transition-colors">Who We Help</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-slate-800 pt-8 mt-8">
          <p class="text-xs text-slate-500 leading-relaxed text-justify mb-6">
            <strong>Disclaimer:</strong> Infinite Wealth Academy provides financial education and protection planning guidance. We are not a registered investment advisor. Content on this site is for educational purposes only. Discuss any legal, tax, or financial matter with the appropriate professional. Neither the information presented nor any opinion expressed constitutes a solicitation for the purchase or sale of any specific product or financial service. The Financial Needs Analysis is based on the accuracy and completeness of the data provided by the client.
          </p>
          <div class="text-center md:text-left text-sm text-slate-500">
            &copy; 2026 Infinite Wealth Academy. All rights reserved.
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
