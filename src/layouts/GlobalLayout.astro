---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Infinite Wealth Academy', description = 'Helping families protect, grow, and control their financial future. Financial clarity, strategic protection, and generational confidence. Project 500 Families by 2027.' } = Astro.props;

const currentLocale = Astro.currentLocale ?? 'en';
const localePrefix = currentLocale === 'fr' ? '/fr' : '';

const pathname = Astro.url.pathname || '/';
const englishPath = pathname.startsWith('/fr') ? (pathname.replace(/^\/fr(?=\/|$)/, '') || '/') : pathname;
const frenchPath = pathname.startsWith('/fr') ? pathname : `/fr${pathname === '/' ? '' : pathname}`;
---
<html lang={currentLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/gold-logo-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/gold-logo-icon.png" />
    <link rel="apple-touch-icon" href="/gold-logo-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body class="font-sans antialiased text-slate-900 bg-white flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-slate-900 focus:rounded-md">Skip to main content</a>

    <!-- Sticky Header (Deep navy #1A2C46 – blends with hero) -->
    <header class="sticky top-0 z-50 w-full border-b border-white/10 shadow-sm" style="background-color: #1A2C46;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <a
            href={localePrefix || '/'}
            class="flex items-center gap-3 shrink-0 group"
            aria-label="Infinite Wealth Academy Home"
          >
            <img
              src="/logo-icon-blended.webp"
              alt="Infinite Wealth Academy logo"
              class="h-12 w-auto md:h-[3.75rem] object-contain block"
              loading="eager"
              decoding="async"
            />
            <span
              class="brand-wordmark text-[20px] md:text-[21px] leading-none whitespace-nowrap"
            >
              Infinite Wealth Academy
            </span>
          </a>

          <nav class="hidden md:flex space-x-8">
            <a href={`${localePrefix}/`} class="font-medium transition-colors hover:opacity-90" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Accueil' : 'Home'}</a>
            <a href={`${localePrefix}/mission`} class="font-medium transition-colors hover:opacity-90" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Mission' : 'Mission'}</a>
            <a href={`${localePrefix}/who-we-help`} class="font-medium transition-colors hover:opacity-90" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Qui nous aidons' : 'Who We Help'}</a>
            <a href={`${localePrefix}/blog`} class="font-medium transition-colors hover:opacity-90" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Insights' : 'Insights'}</a>
            <a href={`${localePrefix}/resources`} class="font-medium transition-colors hover:opacity-90" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Ressources' : 'Resources'}</a>
          </nav>

          <div class="hidden md:flex items-center gap-4">
            <div class="flex items-center gap-3 border-l border-white/10 pl-4">
              <a href={englishPath} class="text-sm font-bold transition-colors hover:opacity-90" style={`color: ${currentLocale === 'en' ? '#CCA03F' : '#E0E4EB'};`}>EN</a>
              <span class="text-slate-600">|</span>
              <a href={frenchPath} class="text-sm font-bold transition-colors hover:opacity-90" style={`color: ${currentLocale === 'fr' ? '#CCA03F' : '#E0E4EB'};`}>FR</a>
            </div>
            <a href={`${localePrefix}/book`} class="inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-bold rounded-md transition-all shadow-md hover:brightness-110" style="background-color: #CCA03F; color: #FFFFFF;">
              {currentLocale === 'fr' ? 'Consultation gratuite' : 'Get a Free Consultation'}
            </a>
          </div>

          <div class="flex md:hidden items-center">
            <button type="button" id="mobile-menu-button" class="p-2 rounded-md hover:opacity-80" style="color: #FFFFFF;" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
              <svg class="w-6 h-6 menu-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
              <svg class="w-6 h-6 menu-close hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 py-4" aria-label="Mobile navigation">
          <nav class="flex flex-col gap-2">
            <a href={`${localePrefix}/`} class="px-2 py-2 rounded-md font-medium hover:bg-white/10" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Accueil' : 'Home'}</a>
            <a href={`${localePrefix}/mission`} class="px-2 py-2 rounded-md font-medium hover:bg-white/10" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Mission' : 'Mission'}</a>
            <a href={`${localePrefix}/who-we-help`} class="px-2 py-2 rounded-md font-medium hover:bg-white/10" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Qui nous aidons' : 'Who We Help'}</a>
            <a href={`${localePrefix}/blog`} class="px-2 py-2 rounded-md font-medium hover:bg-white/10" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Insights' : 'Insights'}</a>
            <a href={`${localePrefix}/resources`} class="px-2 py-2 rounded-md font-medium hover:bg-white/10" style="color: #FFFFFF;">{currentLocale === 'fr' ? 'Ressources' : 'Resources'}</a>

            <div class="mt-2 flex items-center justify-center gap-3 border-t border-white/10 pt-3">
              <a href={englishPath} class="text-sm font-bold transition-colors hover:opacity-90" style={`color: ${currentLocale === 'en' ? '#CCA03F' : '#E0E4EB'};`}>EN</a>
              <span class="text-slate-600">|</span>
              <a href={frenchPath} class="text-sm font-bold transition-colors hover:opacity-90" style={`color: ${currentLocale === 'fr' ? '#CCA03F' : '#E0E4EB'};`}>FR</a>
            </div>

            <a href={`${localePrefix}/book`} class="mt-2 inline-flex items-center justify-center px-5 py-3 text-sm font-bold rounded-md text-white hover:brightness-110" style="background-color: #CCA03F;">{currentLocale === 'fr' ? 'Consultation gratuite' : 'Get a Free Consultation'}</a>
          </nav>
        </div>
      </div>
    </header>
    <script>
      (function() {
        var btn = document.getElementById('mobile-menu-button');
        var menu = document.getElementById('mobile-menu');
        var openIcon = document.querySelector('.menu-open');
        var closeIcon = document.querySelector('.menu-close');
        if (!btn || !menu) return;
        function setOpen(open) {
          menu.classList.toggle('hidden', open);
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
          if (openIcon && closeIcon) { openIcon.classList.toggle('hidden', !open); closeIcon.classList.toggle('hidden', open); }
        }
        btn.addEventListener('click', function() { setOpen(!menu.classList.contains('hidden')); });
        menu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', function() { setOpen(true); }); });
      })();
    </script>

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <!-- Footer (Deep Navy matching header) -->
    <footer class="pt-16 pb-8 border-t border-slate-800" style="background-color: #1A2C46;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12 md:items-center">
          <div class="col-span-1 md:col-span-2">
            <img
              src="/infinite_wealth_logo_transparent.svg"
              alt="Infinite Wealth Academy"
              class="h-[14rem] md:h-64 w-auto object-contain block brightness-110 contrast-125"
            />
            <p class="mt-4 text-slate-400 text-sm leading-relaxed max-w-lg">
              Helping Families Protect, Grow, and Control Their Financial Future. Financial Clarity. Strategic Protection. Generational Confidence.
            </p>
          </div>

          <div class="col-span-1 md:pt-4">
            <h4 class="text-amber-500 font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2 text-sm text-slate-400">
              <li><a href={`${localePrefix}/`} class="hover:text-white transition-colors">{currentLocale === 'fr' ? 'Accueil' : 'Home'}</a></li>
              <li><a href={`${localePrefix}/mission`} class="hover:text-white transition-colors">{currentLocale === 'fr' ? 'Mission' : 'Mission'}</a></li>
              <li><a href={`${localePrefix}/who-we-help`} class="hover:text-white transition-colors">{currentLocale === 'fr' ? 'Qui nous aidons' : 'Who We Help'}</a></li>
              <li><a href={`${localePrefix}/resources`} class="hover:text-white transition-colors">{currentLocale === 'fr' ? 'Ressources' : 'Resources'}</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-slate-800 pt-8 mt-8">
          <p class="text-xs text-slate-500 leading-relaxed text-justify mb-6">
            <strong>Disclaimer:</strong> Infinite Wealth Academy provides financial education and protection planning guidance. We are not a registered investment advisor. Content on this site is for educational purposes only. Discuss any legal, tax, or financial matter with the appropriate professional. Neither the information presented nor any opinion expressed constitutes a solicitation for the purchase or sale of any specific product or financial service. The Financial Needs Analysis is based on the accuracy and completeness of the data provided by the client.
          </p>

          <div class="flex flex-col md:flex-row justify-between items-center">
            <div class="text-center md:text-left text-sm text-slate-500 mb-4 md:mb-0">
              &copy; 2026 Infinite Wealth Academy. All rights reserved.
            </div>

            <!-- Social Media Icons -->
            <div class="flex space-x-6">
              <!-- LinkedIn -->
              <a
                href="https://www.linkedin.com/in/koumba-koundouno-infinite-wealth-academy-403921377/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-amber-500 transition-colors"
                aria-label="LinkedIn"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452H16.89v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.345V9h3.414v1.561h.05c.476-.9 1.637-1.85 3.37-1.85 3.603 0 4.268 2.372 4.268 5.456v6.285zM5.337 7.433a2.063 2.063 0 1 1 .001-4.126 2.063 2.063 0 0 1-.001 4.126zM7.119 20.452H3.556V9h3.563v11.452z" />
                </svg>
              </a>

              <!-- Facebook -->
              <a
                href="https://web.facebook.com/profile.php?id=61576616690894"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-amber-500 transition-colors"
                aria-label="Facebook"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                    clip-rule="evenodd"
                  ></path>
                </svg>
              </a>

              <!-- Instagram -->
              <a
                href="https://www.instagram.com/infinite_wealthacademy/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-amber-500 transition-colors"
                aria-label="Instagram"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                    clip-rule="evenodd"
                  ></path>
                </svg>
              </a>

              <!-- TikTok -->
              <a
                href="https://www.tiktok.com/@infinite_wealth_academy?is_from_webapp=1&sender_device=pc"
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-amber-500 transition-colors"
                aria-label="TikTok"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.12-.51 4.24-1.66 6.08-1.22 1.94-3.1 3.31-5.32 3.84-2.22.52-4.63.35-6.68-.69-2.02-1.02-3.57-2.73-4.32-4.81-.74-2.06-.71-4.41.13-6.44 1.11-2.69 3.49-4.7 6.27-5.18 1.48-.25 3.01-.15 4.43.34v4.13c-.63-.22-1.3-.32-1.96-.28-1.22.04-2.42.53-3.25 1.42-.82.87-1.18 2.08-1.07 3.3.11 1.22.71 2.33 1.65 3.04.94.7 2.19 1 3.36.85 1.17-.14 2.22-.76 2.94-1.7.67-.88 1.03-2 1.05-3.12.04-5.33.02-10.67.02-15.99h-3.7z"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
