---
import GlobalLayout from '../../layouts/GlobalLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<GlobalLayout title="Insights & Education | Infinite Wealth Academy" description="Empowering families to understand how money works. Strategies for income protection, tax advantages, and building a lasting legacy.">
  <!-- Blog Hero: logo blended, fully in frame (contain), navy gradient overlay -->
  <section class="relative overflow-hidden py-20 lg:py-24 border-b border-amber-500/20 text-white" style="background-color: #1A2C46;">
    <!-- Logo layer: full logo visible, large and clearly visible (object-contain) -->
    <img
      src="/infinite_wealth_logo_transparent.svg"
      alt=""
      class="absolute inset-0 z-0 w-full h-full object-contain object-center p-4 md:p-8"
      style="opacity: 0.55;"
      loading="eager"
      aria-hidden="true"
    />
    <!-- Lighter gradient so logo shows through clearly -->
    <div
      class="absolute inset-0 z-[1] pointer-events-none"
      style="background: linear-gradient(to right, #1A2C46 0%, rgba(26,44,70,0.6) 40%, rgba(26,44,70,0.35) 50%, rgba(26,44,70,0.6) 60%, #1A2C46 100%);"
      aria-hidden="true"
    />
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6" style="color: #FFFFFF;">
        Insights & <span style="color: #CCA03F;">Education</span>
      </h1>
      <p class="text-xl max-w-2xl mx-auto leading-relaxed" style="color: #E0E4EB;">
        Empowering families to understand how money works. Discover strategies for income protection, tax advantages, and building a lasting legacy.
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-20 min-h-screen bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {sortedPosts.map((post) => (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 border border-slate-100 flex flex-col">
            {post.data.image && (
              <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover border-b" style="border-color: rgba(204,160,63,0.2);" />
            )}
            <div class="p-8 flex-grow flex flex-col">
              <p class="text-sm font-bold mb-2 uppercase tracking-wide" style="color: #CCA03F;">
                {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </p>
              <h2 class="text-2xl font-bold text-slate-900 mb-3 leading-tight">
                <a href={`/blog/${post.id}`} class="hover:opacity-80 transition-opacity" style="color: inherit;">{post.data.title}</a>
              </h2>
              <p class="text-slate-600 mb-6 flex-grow leading-relaxed text-sm">
                {post.data.description}
              </p>
              <a href={`/blog/${post.id}`} class="inline-flex items-center font-bold transition-opacity hover:opacity-80 text-slate-900">
                Read Article <span class="ml-2" style="color: #CCA03F;">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</GlobalLayout>
