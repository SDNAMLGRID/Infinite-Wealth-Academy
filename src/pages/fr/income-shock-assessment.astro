---
import GlobalLayout from '../../layouts/GlobalLayout.astro';

const assessmentUrl =
  'https://incomeshieldlabs.com/quiz/start?ref=user_3ASlYXpUox6nbBXRZ2xVw2Qentr';
---

<GlobalLayout
  title="Évaluation Income Shock | Infinite Wealth Academy"
  description="Faites l'évaluation Income Shock en 2 minutes et découvrez votre score de risque de revenu."
>
  <section class="py-14 border-b border-white/10" style="background-color: #1A2C46;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">
        Évaluation Income Shock
      </h1>
      <p class="mt-3 text-lg max-w-3xl" style="color: #E0E4EB;">
        Faites cette évaluation en 2 minutes pour obtenir votre score de risque de revenu et votre prochaine action recommandée.
      </p>
      <p class="mt-3 text-sm font-semibold max-w-3xl" style="color: #CCA03F;">
        Important : veuillez saisir une adresse e-mail valide dans l’évaluation afin de recevoir votre recommandation de prochaine étape.
      </p>
    </div>
  </section>

  <section class="py-8 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-md overflow-hidden">
        <iframe
          src={assessmentUrl}
          title="Évaluation Income Shock"
          class="w-full min-h-[75vh] md:min-h-[82vh]"
          loading="eager"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>

      <div class="mt-5 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-600">
        Si l’évaluation ne se charge pas dans cette page, ouvrez-la directement:
        <a
          href={assessmentUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 font-semibold"
          style="color:#CCA03F;"
        >
          Ouvrir l’évaluation Income Shock
        </a>
      </div>
    </div>
  </section>
</GlobalLayout>
