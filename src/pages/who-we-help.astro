---
// src/pages/who-we-help.astro
import GlobalLayout from '../layouts/GlobalLayout.astro';
---

<GlobalLayout>
  <!-- Hero Section -->
  <section class="bg-blue-900 text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">
        Moving From Uncertainty to Clarity and Confidence
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        We help families from all walks of life make informed financial choices that support both today's needs and tomorrow's goals.
      </p>
    </div>
  </section>

  <!-- Core Audiences Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-extrabold text-gray-900">Who We Serve</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Our specialized guidance is designed to simplify complex financial topics so you can feel informed and in control of your future.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Families -->
        <div class="bg-gray-50 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100">
          <h3 class="text-xl font-bold text-blue-900 mb-3">Families</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            Through our "Project 500 Families" mission, we provide education, thoughtful strategy, and personalized guidance to help you build protection, flexibility, and lasting financial security.
          </p>
        </div>
        <!-- Individuals -->
        <div class="bg-gray-50 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100">
          <h3 class="text-xl font-bold text-blue-900 mb-3">Individuals</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            We believe you deserve to understand your financial future. We empower you with financial education first, so you understand exactly how money works.
          </p>
        </div>
        <!-- Professionals -->
        <div class="bg-gray-50 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100">
          <h3 class="text-xl font-bold text-blue-900 mb-3">Professionals</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            We design customized strategies that adapt to life's changes, ensuring you have income protection, tax-advantaged strategies, and retirement income flexibility.
          </p>
        </div>
        <!-- Business Owners -->
        <div class="bg-gray-50 rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100">
          <h3 class="text-xl font-bold text-blue-900 mb-3">Business Owners</h3>
          <p class="text-gray-600 leading-relaxed text-sm">
            We simplify complex protection strategies to guard your assets and help you build long-term strategies designed to outpace inflation and create a lasting family legacy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Value Proposition CTA -->
  <section class="py-20 bg-blue-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-blue-900 mb-6">Beyond Saving. Toward Strategic Protection.</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-10">
        Saving alone isn't enough. Many traditional advice models overlook protection and flexibility. We help you position your finances for protection, flexibility, and long-term control so you can navigate the risks most families don't see coming.
      </p>
      <a href="https://calendly.com/500families-infinitewealthacademy/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-bold rounded-md text-white bg-blue-900 hover:bg-blue-800 transition-colors shadow-lg">
        Book a Strategy Session
      </a>
    </div>
  </section>

</GlobalLayout>
