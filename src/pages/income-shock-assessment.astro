---
import GlobalLayout from '../layouts/GlobalLayout.astro';

const assessmentUrl =
  'https://incomeshieldlabs.com/quiz/start?ref=user_3ASlYXpUox6nbBXRZ2xVw2Qentr';
---

<GlobalLayout
  title="Income Shock Assessment | Infinite Wealth Academy"
  description="Take the 2-minute Income Shock Assessment and get your Income Risk Score."
>
  <section class="py-14 border-b border-white/10" style="background-color: #1A2C46;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">
        Income Shock Assessment
      </h1>
      <p class="mt-3 text-lg max-w-3xl" style="color: #E0E4EB;">
        Complete this 2-minute assessment to see your Income Risk Score and identify your next best step.
      </p>
      <p class="mt-3 text-sm font-semibold max-w-3xl" style="color: #CCA03F;">
        Important: please enter a valid email address in the assessment to receive your next-step recommendation.
      </p>
    </div>
  </section>

  <section class="py-8 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-md overflow-hidden">
        <iframe
          src={assessmentUrl}
          title="Income Shock Assessment"
          class="w-full min-h-[75vh] md:min-h-[82vh]"
          loading="eager"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>

      <div class="mt-5 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-600">
        If the assessment does not load in this window, open it directly:
        <a
          href={assessmentUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 font-semibold"
          style="color:#CCA03F;"
        >
          Launch Income Shock Assessment
        </a>
      </div>
    </div>
  </section>
</GlobalLayout>
