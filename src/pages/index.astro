---
import GlobalLayout from '../layouts/GlobalLayout.astro';
import OfferingsGrid from '../components/OfferingsGrid.astro';
import TeamGrid from '../components/TeamGrid.astro';
---

<GlobalLayout title="Infinite Wealth Academy | Protect, Grow & Control Your Financial Future" description="Secure your family's financial future with generational confidence. Strategic protection and tailored financial plans. Free consultation.">
  <!-- Hero: full-bleed blended split – family image as background, navy left with gradient blend (~75vh) -->
  <section class="relative min-h-[78vh] overflow-hidden flex flex-col justify-center" aria-label="Hero">
    <!-- Full-width background image (right-aligned so family is prominent) -->
    <div
      class="absolute inset-0 z-0 bg-cover bg-no-repeat"
      style="background-image: url('/hero-family.webp.png'); background-position: right center;"
      role="img"
      aria-hidden="true"
    />
    <!-- Gradient overlay: solid navy left, blending into image (family “walking into” the blue) -->
    <div
      class="absolute inset-0 z-[1]"
      style="background: linear-gradient(to right, #1A2C46 0%, #1A2C46 45%, rgba(26,44,70,0.97) 52%, rgba(26,44,70,0.85) 62%, rgba(26,44,70,0.5) 74%, transparent 88%);"
      aria-hidden="true"
    />
    <!-- On small screens: light tint over image so text stays readable -->
    <div
      class="absolute inset-0 z-[1] bg-[#1A2C46]/50 md:bg-transparent"
      aria-hidden="true"
    />
    <!-- Content: left-aligned over solid navy, generous padding for high-end feel -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-xl text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight" style="color: #FFFFFF;">
          Secure Your Family's Financial Future with Generational Confidence
        </h1>
        <p class="text-xl mb-10 leading-relaxed" style="color: #E0E4EB;">
          Unlock a clear path to lasting wealth. We provide strategic protection and tailored financial plans so you can build and preserve legacy for generations.
        </p>
        <div class="flex flex-wrap justify-center lg:justify-start gap-4">
          <a
            href="https://calendly.com/500families-infinitewealthacademy/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 font-bold rounded-lg text-lg transition-all duration-300 hover:brightness-110 hover:scale-[1.02] shadow-lg"
            style="background-color: #CCA03F; color: #FFFFFF;"
          >
            Start Your Legacy: Schedule a Free Consultation
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- Decorative bar under hero (gold accent, soft fade) -->
  <div class="h-1.5 w-full" style="background: linear-gradient(to right, #CCA03F 0%, rgba(204,160,63,0.6) 40%, transparent 100%);" aria-hidden="true"></div>

  <!-- CTA: Interactive Tools -->
  <section class="py-12" style="background-color: #1A2C46;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight" style="color: #FFFFFF;">
            Get clarity in under 60 seconds
          </h2>
          <p class="mt-2 text-base md:text-lg max-w-2xl" style="color: #E0E4EB;">
            Use our Retirement Income Gap Calculator and Financial Clarity Assessment to uncover the risks most families don’t see coming—and learn what to do next.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
          <a
            href="/resources"
            class="inline-flex items-center justify-center px-7 py-4 font-bold rounded-lg text-base transition-all duration-300 hover:brightness-110 hover:scale-[1.02] shadow-lg w-full md:w-auto"
            style="background-color: #CCA03F; color: #FFFFFF;"
          >
            Try the Interactive Tools
          </a>
          <a
            href="https://calendly.com/500families-infinitewealthacademy/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-7 py-4 font-bold rounded-lg text-base transition-all duration-300 hover:bg-white/10 border border-white/20 w-full md:w-auto"
            style="color: #FFFFFF;"
          >
            Book a Strategy Session
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem & Solution -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-extrabold text-slate-900">Why Infinite Wealth Academy Exists</h2>
        <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
          Financial confusion is costing families security. Traditional advice often overlooks protection and flexibility. Project 500 Families is about changing that.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-slate-900 mb-6 border-b border-amber-200 pb-4">Financial Risks Most Families Don't See Coming</h3>
          <ul class="space-y-4 text-slate-600 font-medium">
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> What happens to retirement accounts after leaving a job</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> Why many families are underinsured</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> The retirement income gap</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> The difference between saving and positioning</li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-slate-900 mb-6 border-b border-amber-200 pb-4">Financial Protection Should Be Simple</h3>
          <ul class="space-y-4 text-slate-600 font-medium">
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> Income protection</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> Tax-advantaged strategies</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> Living benefits</li>
            <li class="flex items-start"><span class="text-amber-500 mr-2">✔</span> Retirement income flexibility</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <OfferingsGrid />

  <!-- Testimonials -->
  <section class="py-20 bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold mb-16"><span class="text-amber-500">What My Clients Say</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-slate-800 p-8 rounded-2xl flex flex-col items-center border border-slate-700">
          <img loading="lazy" src="/michael-headshot.webp" alt="Michael Lynch" class="w-20 h-20 rounded-full object-cover mb-6 border-2 border-amber-500 shadow-md" />
          <p class="italic text-slate-300 mb-6 flex-grow">"Before working with Koumba, we thought saving was enough. She helped us understand protection and flexibility in a way that finally made sense. We feel more confident about our future."</p>
          <p class="font-bold text-amber-500">— Michael Lynch</p>
        </div>
        <div class="bg-slate-800 p-8 rounded-2xl flex flex-col items-center border border-slate-700">
          <img loading="lazy" src="/camillus-headshot.png" alt="Camillus Alemoh" class="w-20 h-20 rounded-full object-cover mb-6 border-2 border-amber-500 shadow-md" />
          <p class="italic text-slate-300 mb-6 flex-grow">"Koumba has a gift for simplifying complex financial topics. Instead of feeling overwhelmed, we now feel informed and in control."</p>
          <p class="font-bold text-amber-500">— Camillus Alemoh</p>
        </div>
        <div class="bg-slate-800 p-8 rounded-2xl flex flex-col items-center border border-slate-700">
          <img loading="lazy" src="/victoria-headshot.webp" alt="Victoria Amusa" class="w-20 h-20 rounded-full object-cover mb-6 border-2 border-amber-500 shadow-md" />
          <p class="italic text-slate-300 mb-6 flex-grow">"The clarity we gained during our strategy session changed how we think about retirement planning. We finally understand our options."</p>
          <p class="font-bold text-amber-500">— Victoria Amusa</p>
        </div>
      </div>
    </div>
  </section>

  <TeamGrid />
</GlobalLayout>
