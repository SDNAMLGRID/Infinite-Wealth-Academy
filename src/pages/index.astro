---
// src/pages/index.astro
import GlobalLayout from '../layouts/GlobalLayout.astro';
import OfferingsGrid from '../components/OfferingsGrid.astro';
import TeamGrid from '../components/TeamGrid.astro';
---

<GlobalLayout>
  <!-- Hero Section -->
  <section class="bg-blue-900 text-white py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
        Protecting 500 Families by 2027 Through Smarter Financial Positioning
      </h1>
      <p class="text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto mb-10 leading-relaxed">
        Helping Families Protect, Grow, and Control Their Financial Future. <br class="hidden md:block" /> 
        <span class="font-semibold text-white">Financial Clarity. Strategic Protection. Generational Confidence.</span>
      </p>
      <div class="flex justify-center gap-4">
        <a href="https://calendly.com/500families-infinitewealthacademy/30min" target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-white text-blue-900 font-bold rounded-lg shadow-lg hover:bg-gray-50 transition-colors duration-300 text-lg">
          Schedule Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Problem & Solution -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-extrabold text-gray-900">Why Infinite Wealth Academy Exists</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Financial confusion is costing families security. Traditional advice often overlooks protection and flexibility. Project 500 Families is about changing that.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold text-red-700 mb-6">Financial Risks Most Families Don't See Coming</h3>
          <ul class="space-y-4 text-gray-600 font-medium">
            <li>✔ What happens to retirement accounts after leaving a job</li>
            <li>✔ Why many families are underinsured</li>
            <li>✔ The retirement income gap</li>
            <li>✔ The difference between saving and positioning</li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-2xl font-bold text-green-700 mb-6">Financial Protection Should Be Simple</h3>
          <ul class="space-y-4 text-gray-600 font-medium">
            <li>✔ Income protection</li>
            <li>✔ Tax-advantaged strategies</li>
            <li>✔ Living benefits</li>
            <li>✔ Retirement income flexibility</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <OfferingsGrid />

  <!-- Testimonials Section -->
  <section class="py-20 bg-blue-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold mb-12">What My Clients Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-blue-800 p-8 rounded-xl">
          <p class="italic text-blue-100 mb-6">"Before working with Koumba, we thought saving was enough. She helped us understand protection and flexibility in a way that finally made sense. We feel more confident about our future."</p>
          <p class="font-bold text-white">— Michael Lynch</p>
        </div>
        <div class="bg-blue-800 p-8 rounded-xl">
          <p class="italic text-blue-100 mb-6">"Koumba has a gift for simplifying complex financial topics. Instead of feeling overwhelmed, we now feel informed and in control."</p>
          <p class="font-bold text-white">— Camillus Alemoh</p>
        </div>
        <div class="bg-blue-800 p-8 rounded-xl">
          <p class="italic text-blue-100 mb-6">"The clarity we gained during our strategy session changed how we think about retirement planning. We finally understand our options."</p>
          <p class="font-bold text-white">— Victoria Amusa</p>
        </div>
      </div>
    </div>
  </section>

  <TeamGrid />

</GlobalLayout>
